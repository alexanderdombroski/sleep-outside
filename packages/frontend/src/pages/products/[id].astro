---
import type { Product } from "../../../../shared/types/schemas.mts";
import Layout from "../../layouts/Layout.astro";
import ColorPicker from "../../components/ColorPicker.svelte";
import { type CollectionEntry, getCollection } from "astro:content";
import AddProduct from "../../components/AddProduct.svelte";

export async function getStaticPaths() {
  const products = await getCollection("products");

  return products.map((product) => ({
    params: { id: product.id },
    props: product,
  }));
}

type Props = CollectionEntry<"products">;
const productCollectionItem = Astro.props;
const product: Product = productCollectionItem.data;
---

<Layout title={product.name}>
  <section class="product-detail">
    <h2 class="divider">{product.name}</h2>

    <img
      class="divider"
      src={product.images.primaryExtraLarge}
      alt={product.name}
    />

    <div class="prices">
      <p class="product-card__price">${product.listPrice}</p>
      <p class="product-card__discount">
        {
          product.discountPercentage
            ? `${product.discountPercentage}% off`
            : "No discount"
        }
      </p>
      <p class="product-card__final-price">${product.finalPrice}</p>
    </div>

    {
      product.colors && (
        <div class="product__color">
          <ColorPicker client:load colors={product.colors} />
        </div>
      )
    }
    <p class="product__description" set:html={product.descriptionHtmlSimple} />
    <p>Only <b>{product.stock}</b> left in stock!</p>

    <AddProduct client:only="svelte" {product} />
  </section>
</Layout>

<style>
  .prices {
    display: flex;
    flex-direction: row;
    justify-content: space-around;

    .product-card__price {
      text-decoration: line-through;
    }
    .product-card__final-price {
      font-weight: bold;
    }
  }
</style>

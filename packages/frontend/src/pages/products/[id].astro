---
import type { Product } from "../../../../shared/types/schemas.mts";
import Layout from "../../layouts/Layout.astro";
import ColorPicker from "../../components/ColorPicker.svelte";
import { type CollectionEntry, getCollection } from "astro:content";

export async function getStaticPaths() {
  const products = await getCollection("products");

  return products.map((product) => ({
    params: { id: product.id },
    props: product,
  }));
}

type Props = CollectionEntry<"products">;
const productCollectionItem = Astro.props;
const product: Product = productCollectionItem.data;
---

<Layout title={product.name}>
  <section class="product-detail">
    <h2 class="divider">{product.name}</h2>

    <img
      class="divider"
      src={product.images.primaryExtraLarge}
      alt={product.name}
    />

    <div class="prices">
      <p class="product-card__price">${product.listPrice}</p>
      <p class="product-card__discount">
        {
          product.discountPercentage
            ? `${product.discountPercentage}% off`
            : "No discount"
        }
      </p>
      <p class="product-card__final-price">${product.finalPrice}</p>
    </div>

    {
      product.colors && (
        <div class="product__color">
          <ColorPicker client:load colors={product.colors} />
        </div>
      )
    }
    <p class="product__description" set:html={product.descriptionHtmlSimple} />
    <p>Only <b>{product.stock}</b> left in stock!</p>

    <div class="product-detail__add">
      <button id="addToCart" data-product={JSON.stringify(product)}>
        Add to Cart
      </button>
    </div>
  </section>
</Layout>

<style>
  .prices {
    display: flex;
    flex-direction: row;
    justify-content: space-around;

    .product-card__price {
      text-decoration: line-through;
    }
    .product-card__final-price {
      font-weight: bold;
    }
  }
</style>

<script>
  import { addToCart } from "../../js/cart.ts";
  import { sendAlert } from "../../components/alert/alert.svelte.ts";
  import type { AlertOptions } from "../../components/alert";
  import type { Color } from "../../../../shared/types/schemas.mts";

  const addBtn = document.querySelector("#addToCart");

  let selectedColor: Color;
  function selectColor(color: Color) {
    selectedColor = color;
  }
  // @ts-expect-error ts(2339)
  window.selectColor = selectColor;

  if (addBtn) {
    addBtn.addEventListener("click", (event) => {
      const target = event.currentTarget as HTMLButtonElement;
      const productString = target.dataset.product;

      if (productString) {
        const productData = JSON.parse(productString);
        if (selectedColor) {
          addToCart(productData, selectedColor.colorName);

          const alertOptions: AlertOptions = {
            message: `${productData.name} was added to your cart!`,
            type: "success",
            duration: 3000,
          };
          sendAlert(alertOptions);
        } else {
          const alertOptions: AlertOptions = {
            message: `please select a color`,
            type: "warning",
            duration: 1000,
          };
          sendAlert(alertOptions);
        }
      }
    });
  }
</script>
